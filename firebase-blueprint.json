{
  "entities": {
    "Car": {
      "title": "Car",
      "description": "A vehicle listing in the showroom.",
      "type": "object",
      "properties": {
        "make": { "type": "string", "description": "Car manufacturer (e.g., BMW, Audi)." },
        "model": { "type": "string", "description": "Car model (e.g., M3, R8)." },
        "year": { "type": "number", "description": "Manufacturing year." },
        "price": { "type": "number", "description": "Price in USD." },
        "mileage": { "type": "number", "description": "Mileage in miles." },
        "description": { "type": "string", "description": "Detailed description of the car." },
        "images": { 
          "type": "array", 
          "items": { "type": "string" }, 
          "description": "List of image URLs." 
        },
        "features": { 
          "type": "array", 
          "items": { "type": "string" }, 
          "description": "List of features (e.g., Sunroof, Leather Seats)." 
        },
        "status": { 
          "type": "string", 
          "enum": ["Available", "Sold", "Reserved"], 
          "description": "Current status of the car." 
        },
        "slug": { "type": "string", "description": "SEO-friendly URL slug." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["make", "model", "year", "price", "status", "slug"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A customer inquiry about a car.",
      "type": "object",
      "properties": {
        "carId": { "type": "string", "description": "ID of the car being inquired about." },
        "userId": { "type": "string", "description": "ID of the user making the inquiry (optional)." },
        "name": { "type": "string", "description": "Name of the inquirer." },
        "email": { "type": "string", "format": "email", "description": "Email of the inquirer." },
        "phone": { "type": "string", "description": "Phone number of the inquirer." },
        "message": { "type": "string", "description": "Message content." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of the inquiry." },
        "status": { 
          "type": "string", 
          "enum": ["New", "Read", "Replied", "Archived"], 
          "description": "Status of the inquiry." 
        }
      },
      "required": ["name", "email", "message", "createdAt", "status"]
    },
    "User": {
      "title": "User",
      "description": "A registered user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID." },
        "email": { "type": "string", "format": "email", "description": "User email." },
        "role": { 
          "type": "string", 
          "enum": ["admin", "user"], 
          "description": "User role." 
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registration timestamp." }
      },
      "required": ["uid", "email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global site settings.",
      "type": "object",
      "properties": {
        "siteName": { "type": "string", "description": "Name of the website." },
        "contactEmail": { "type": "string", "format": "email", "description": "Contact email address." },
        "contactPhone": { "type": "string", "description": "Contact phone number." },
        "address": { "type": "string", "description": "Physical address." },
        "socialLinks": { 
          "type": "object", 
          "description": "Social media links.",
          "properties": {
            "facebook": { "type": "string" },
            "twitter": { "type": "string" },
            "instagram": { "type": "string" }
          }
        }
      }
    }
  },
  "firestore": {
    "cars/{carId}": {
      "schema": "Car",
      "description": "Collection of cars."
    },
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Collection of inquiries."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of users."
    },
    "settings/global": {
      "schema": "Settings",
      "description": "Global settings document."
    }
  }
}
